# PostgreSQL Admin (superuser for administration and local connections)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=your_admin_password_here

# Backend Database
BACKEND_DB_NAME=backend
BACKEND_DB_USER=backend_user
BACKEND_DB_PASSWORD=your_backend_db_password_here

# LangFlow Database
LANGFLOW_DB_NAME=langflow
LANGFLOW_DB_USER=langflow_user
LANGFLOW_DB_PASSWORD=your_langflow_db_password_here

# LangFlow
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=your_secure_password
LANGFLOW_SECRET_KEY=your_secret_key_here

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=windchasersecurity

# Backend
ENVIRONMENT=local
APP_VERSION=0.1.0
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:3000","http://localhost:5173"]
CORS_HEADERS=["*"]

# LLM API
LANGFLOW_OPENAI_API_KEY= # для langflow
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://foundation-models.api.cloud.ru/v1
OPENAI_MODEL=ai-sage/GigaChat3-10B-A1.8B
# Специфичные настройки агентов (опционально, fallback на OPENAI_MODEL)
OPENAI_EVALUATOR_MODEL=                       # пусто = используется OPENAI_MODEL
OPENAI_EVALUATOR_TEMPERATURE=0.5
OPENAI_TUTOR_MODEL=                           # пусто = используется OPENAI_MODEL
OPENAI_TUTOR_TEMPERATURE=0.7
